# ─── Azure AD / Microsoft Graph ─────────────────────────────────────────────
# App registration "OSEYS-ProspectionAgent"
TENANT_ID=70f9e20f-964f-4925-8dc2-b72d62384629
CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Boîtes mail autorisées ─────────────────────────────────────────────────
DAVID_EMAIL=david@oseys.fr
MARTIN_EMAIL=martin@oseys.fr
MILA_EMAIL=mila@oseys.fr

# ─── Pipedrive ──────────────────────────────────────────────────────────────
PIPEDRIVE_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PIPEDRIVE_COMPANY_DOMAIN=oseys
PIPEDRIVE_STAGE_NEW=1
PIPEDRIVE_STAGE_CONTACTED=2
PIPEDRIVE_STAGE_REPLIED=3
PIPEDRIVE_STAGE_CLOSED_LOST=4

# ─── Anthropic (génération de séquences) ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Azure Storage (file d'attente pour J3/J7/J14) ──────────────────────────
AzureWebJobsStorage=DefaultEndpointsProtocol=https;AccountName=...
QUEUE_NAME_RELANCES=mila-relances

# ─── Interne ────────────────────────────────────────────────────────────────
ADMIN_EMAIL=paul.rudler@oseys.fr
PUBLIC_FORMS_BASE_URL=https://groupeperenne.github.io/Pereneo_agents/forms
FROM_EMAIL=david@oseys.fr
FUNCTION_APP_HOST=oseys-mail-sender-c8cveseah3g8a9gs.francecentral-01.azurewebsites.net
FUNCTION_APP_URL=https://oseys-mail-sender-c8cveseah3g8a9gs.francecentral-01.azurewebsites.net
CHOIXNIVEAU_FUNC_CODE=

# ─── Lead Exhauster (chantier 2) ────────────────────────────────────────────
# Seuil minimal pour accepter une résolution (voir SPEC §1). Résolution
# sous seuil → status='unresolvable', pas d'envoi.
LEAD_EXHAUSTER_CONFIDENCE_THRESHOLD=0.80

# Noms de tables Azure Storage — défaut fonctionnel, override si besoin
# (staging avec tables séparées, par exemple).
LEADCONTACTS_TABLE=LeadContacts
EMAIL_PATTERNS_TABLE=EmailPatterns
EMAIL_BLACKLISTED_PATTERNS_TABLE=EmailBlacklistedPatterns
EMAIL_UNRESOLVABLE_TABLE=EmailUnresolvable
BUDGETS_TABLE=Budgets
EXPERIMENTS_TABLE=Experiments

# API gouv recherche-entreprises (SIREN → site_web). Pas d'auth requise.
RECHERCHE_ENTREPRISES_API_URL=https://recherche-entreprises.api.gouv.fr

# ─── Dropcontact (cascade externe, pay-on-success) ──────────────────────────
# Secret géré par Azure Key Vault en prod : référence
# @Microsoft.KeyVault(SecretUri=...) dans App Settings. Ici en .env.example
# on laisse vide pour signaler la présence de la variable.
DROPCONTACT_API_KEY=
DROPCONTACT_API_URL=https://api.dropcontact.io/batch
# Désactivé par défaut : les tests ne doivent jamais appeler Dropcontact
# en réel. Activer uniquement pour scripts/exhauster-smoke.js --real.
DROPCONTACT_ENABLED=false
# Hard cap mensuel (centimes). 2400 = 24€ plan Starter 1000 crédits.
DROPCONTACT_MONTHLY_BUDGET_CENTS=2400
